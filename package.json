{
  "name": "nix-store-admin",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:server": "cross-env NODE_ENV=development ts-node ./src/index.ts",
    "dev:worker": "cross-env NODE_ENV=development ts-node ./src/index-worker.ts",
    "dev": "cross-env NODE_ENV=development concurrently npm:dev:*",
    "start:server": "cross-env NODE_ENV=production node ./dist/src/index.js",
    "start:worker": "cross-env NODE_ENV=production node ./dist/src/index-worker.js",
    "start": "cross-env NODE_ENV=production concurrently npm:start:*",
    "copy": "npx copyfiles -u 1 'admin-ui/dist/**/*' dist",
    "build": "cross-env NODE_ENV=production tsc && yarn copy",
    "build:admin": "rimraf admin-ui && npx ts-node src/compile-admin-ui.ts",
    "codegen": "graphql-codegen --config codegen.ts",
    "docker:dev": "docker-compose -f docker-compose.dev.yml up --watch",
    "docker:dev:logs": "docker-compose -f docker-compose.dev.yml logs -f",
    "docker:dev:stop": "docker-compose -f docker-compose.dev.yml down",
    "docker:dev:build": "docker-compose -f docker-compose.dev.yml build",
    "docker:dev:restart": "docker-compose -f docker-compose.dev.yml restart",
    "docker:dev:clean": "docker-compose -f docker-compose.dev.yml down -v && docker system prune -f",
    "docker:prod": "docker-compose -f docker-compose.yml up -d",
    "docker:prod:stop": "docker-compose -f docker-compose.yml down",
    "docker:shell": "docker-compose -f docker-compose.dev.yml exec server sh",
    "docker:db": "docker-compose -f docker-compose.dev.yml exec database psql -U postgres -d vendure"
  },
  "dependencies": {
    "@elastic/elasticsearch": "^8.15.0",
    "@vendure/admin-ui-plugin": "3.0.4",
    "@vendure/asset-server-plugin": "3.0.4",
    "@vendure/core": "3.0.4",
    "@vendure/elasticsearch-plugin": "^3.0.4",
    "@vendure/email-plugin": "3.0.4",
    "@vendure/harden-plugin": "^3.0.4",
    "copyfiles": "^2.4.1",
    "dotenv": "16.4.5",
    "pg": "8.13.0"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^5.0.3",
    "@vendure/cli": "3.0.4",
    "@vendure/create": "^3.0.4",
    "@vendure/ui-devkit": "^3.0.5",
    "concurrently": "9.0.1",
    "cross-env": "^7.0.3",
    "typescript": "5.3.3"
  }
}
