{
  "name": "nix-store-admin",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:server": "cross-env NODE_ENV=development ts-node ./src/index.ts",
    "dev:worker": "cross-env NODE_ENV=development ts-node ./src/index-worker.ts",
    "dev": "cross-env NODE_ENV=development concurrently npm:dev:*",
    "start:server": "node ./dist/src/index.js",
    "start:worker": "node ./dist/src/index-worker.js",
    "start": "concurrently npm:start:*",
    "copy": "npx copyfiles -u 1 'admin-ui/dist/**/*' dist",
    "build": "cross-env NODE_ENV=production tsc",
    "build:admin": "rimraf admin-ui && npx ts-node src/compile-admin-ui.ts",
    "codegen": "graphql-codegen --config codegen.ts",
    "migration:generate": "ts-node migration.ts generate",
    "migration:run": "ts-node migration.ts run",
    "migration:revert": "ts-node migration.ts revert",
    "k6:resources": "docker compose run --rm k6 run resource-smoke.js",
    "k6:resources:local": "cross-env K6_BASE_URL=http://host.docker.internal:3000 docker compose run --rm k6 run resource-smoke.js",
    "docker:dev": "docker compose up --build --watch",
    "docker:dev:plain": "docker compose up --build",
    "docker:dev:down": "docker compose down -v",
    "docker:prod": "docker compose -f docker-compose.prod.yml up --build -d",
    "docker:prod:down": "docker compose -f docker-compose.prod.yml down"
  },
  "dependencies": {
    "@as-integrations/express5": "^1.1.2",
    "@elastic/elasticsearch": "^8.15.0",
    "@vendure/admin-ui-plugin": "3.4.1",
    "@vendure/asset-server-plugin": "3.4.1",
    "@vendure/core": "3.4.1",
    "@vendure/elasticsearch-plugin": "3.4.1",
    "@vendure/email-plugin": "3.4.1",
    "@vendure/harden-plugin": "3.4.1",
    "copyfiles": "^2.4.1",
    "dotenv": "16.4.5",
    "pg": "8.13.0"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^5.0.3",
    "@vendure/cli": "3.4.1",
    "@vendure/create": "3.4.1",
    "@vendure/ui-devkit": "3.4.1",
    "concurrently": "9.0.1",
    "cross-env": "^7.0.3",
    "ts-node": "^10.9.2",
    "typescript": "5.8.2"
  }
}
